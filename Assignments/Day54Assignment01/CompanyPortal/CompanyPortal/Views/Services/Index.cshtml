
@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">

    <h2>Our Services</h2>

    <div class="accordion mt-3" id="servicesAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#consulting">
                    Consulting
                </button>
            </h2>
            <div id="consulting" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    Professional consulting services for business growth.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#training">
                    Training
                </button>
            </h2>
            <div id="training" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Industry focused training programs for professionals.
                </div>
            </div>
        </div>

    </div>

</div>

