@model CRUD_Operations.Models.Loan

@{
    ViewData["Title"] = "Edit";
}

<h2>Edit Loan</h2>

<form asp-action="Edit" method="post">

<input type="hidden" asp-for="Id" />

<div asp-validation-summary="All" class="text-danger"></div>

<div class="form-group">
    <label asp-for="BorrowerName"></label>
    <input asp-for="BorrowerName" class="form-control"/>
</div>

<div class="form-group">
    <label asp-for="LenderName"></label>
    <input asp-for="LenderName" class="form-control"/>
</div>

<div class="form-group">
    <label asp-for="Amount"></label>
    <input asp-for="Amount" class="form-control"/>
</div>

<div class="form-check">
    <input asp-for="IsSettled" class="form-check-input"/>
    <label asp-for="IsSettled"></label>
</div>

<br>

<button type="submit" class="btn btn-success">Update</button>

</form>